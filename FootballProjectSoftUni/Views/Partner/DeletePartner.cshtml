@using FootballProjectSoftUni.Core.Models.Partner
@model List<PartnerViewModel>
@inject IStringLocalizer<FootballProjectSoftUni.SharedResource> Localizer


<section class="container py-4">
    <div class="admin-form-card mx-auto">

        <form asp-action="DeleteConfirmed" method="get">

            <div class="mb-3">
                <label class="form-label fw-bold">
                    <i class="bi bi-handshake-fill me-2"></i>@Localizer["DPSelectPartner"]
                </label>

                <select name="id"
                        id="partnerId"
                        class="form-select form-select-lg tg-select">

                    <option value="">-- Select Partner --</option>

                    @foreach (var partner in Model)
                    {
                        <option value="@partner.Id">@partner.Name</option>
                    }

                </select>
            </div>

            <a id="deleteButton"
               class="btn btn-danger btn-lg w-100 tg-action-btn disabled">

                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @Localizer["DPDeletePartner"]
            </a>

        </form>

    </div>

</section>

<script>

    const partnerSelect = document.getElementById('partnerId');
    const deleteButton = document.getElementById('deleteButton');

    partnerSelect.addEventListener('change', function () {

        if (this.value) {
            deleteButton.href = '/Partner/DeleteConfirmed?id=' + this.value;
            deleteButton.classList.remove('disabled');
        }
        else {
            deleteButton.href = '#';
            deleteButton.classList.add('disabled');
        }

    });

</script>
