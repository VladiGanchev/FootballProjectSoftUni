@page
@model ForgotPasswordConfirmation
@inject IStringLocalizer<FootballProjectSoftUni.SharedResource> Localizer
@{
    ViewData["Title"] = "Password Reset Email Sent";
}

<div class="auth-wrap">
    <div class="auth-card text-center">

        <div class="auth-logo mb-3">
            <i class="bi bi-envelope-check-fill"></i>
        </div>

        <h1 class="auth-title mb-2">
            @Localizer["FPCCheckEmail"]
        </h1>

        <p class="auth-subtitle mb-4">
            @Localizer["FPCSentEmail"]
        </p>

        <a asp-page="./Login" class="btn btn-primary auth-btn">
            <i class="bi bi-box-arrow-in-right me-2"></i>
            @Localizer["FPCBackToLogin"]
        </a>

    </div>
</div>
