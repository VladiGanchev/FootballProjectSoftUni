@using FootballProjectSoftUni.Core.Models.Tournament;
@model EditViewModel
@inject IStringLocalizer<FootballProjectSoftUni.SharedResource> Localizer


@{
    ViewBag.Title = "Edit Tournament";
}

<section class="container py-4">

    <div class="admin-form-card mx-auto" style="max-width: 760px;">

        <form asp-action="Edit" method="post" class="admin-form">

            <div class="mb-3">
                <label asp-for="@Model.ImageUrl" class="form-label fw-bold">
                    <i class="bi bi-image-fill me-2"></i>@Localizer["EImaGE"]
                </label>

                <input asp-for="@Model.ImageUrl"
                       class="form-control tg-input"
                       aria-required="true"
                       placeholder="https://..." />

                <span asp-validation-for="@Model.ImageUrl" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="@Model.Description" class="form-label fw-bold">
                    <i class="bi bi-card-text me-2"></i>@Localizer["EEditTopic"]
                </label>

                <input asp-for="@Model.Description"
                       class="form-control tg-input"
                       aria-required="true"
                       placeholder="Tournament description..." />

                <span asp-validation-for="@Model.Description" class="text-danger small"></span>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <div class="mb-3">
                        <label asp-for="@Model.StartDate" class="form-label fw-bold">
                            <i class="bi bi-calendar-event-fill me-2"></i>@Localizer["EStart"]
                        </label>

                        <input asp-for="@Model.StartDate"
                               class="form-control tg-input"
                               aria-required="true"
                               value="@DateTime.Now.ToString("dd/MM/yyyy HH:mm")" />

                        <span asp-validation-for="@Model.StartDate" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="mb-3">
                        <label asp-for="@Model.EndDate" class="form-label fw-bold">
                            <i class="bi bi-calendar-check-fill me-2"></i>@Localizer["EEnd"]
                        </label>

                        <input asp-for="@Model.EndDate"
                               class="form-control tg-input"
                               aria-required="true"
                               value="@DateTime.Now.ToString("dd/MM/yyyy HH:mm")" />

                        <span asp-validation-for="@Model.EndDate" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Winner" class="form-label fw-bold">
                    <i class="bi bi-award-fill me-2"></i>@Localizer["EWinner"]
                </label>

                <input asp-for="Winner"
                       class="form-control tg-input"
                       placeholder="Winner team name (optional)..." />

                <span asp-validation-for="Winner" class="text-danger small"></span>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <div class="mb-3">
                        <label asp-for="Prize" class="form-label fw-bold">
                            <i class="bi bi-trophy-fill me-2"></i>@Localizer["EFirstPlacePrize"]
                        </label>

                        <input asp-for="Prize"
                               class="form-control tg-input"
                               type="number"
                               min="0"
                               step="0.01" />

                        <span asp-validation-for="Prize" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="mb-3">
                        <label asp-for="SecondPlacePrize" class="form-label fw-bold">
                            <i class="bi bi-award-fill me-2"></i>@Localizer["ESecondPlacePrize"]
                        </label>

                        <input asp-for="SecondPlacePrize"
                               class="form-control tg-input"
                               type="number"
                               min="0"
                               step="0.01" />

                        <span asp-validation-for="SecondPlacePrize" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="mb-3">
                        <label asp-for="ThirdPlacePrize" class="form-label fw-bold">
                            <i class="bi bi-award me-2"></i>@Localizer["EThirdPlacePrize"]
                        </label>

                        <input asp-for="ThirdPlacePrize"
                               class="form-control tg-input"
                               type="number"
                               min="0"
                               step="0.01" />

                        <span asp-validation-for="ThirdPlacePrize" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold tg-action-btn">
                <i class="bi bi-save2-fill me-2"></i>
                @Localizer["EFinalEdit"]
            </button>

        </form>

    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
