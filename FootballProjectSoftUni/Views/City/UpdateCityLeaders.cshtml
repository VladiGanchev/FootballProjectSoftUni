@using Microsoft.AspNetCore.Mvc.Rendering
@model FootballProjectSoftUni.Core.Models.City.UpdateCityBestTeamViewModel
@inject IStringLocalizer<FootballProjectSoftUni.SharedResource> Localizer



@{
    ViewBag.Title = "Update City Leaders";
}

<section class="container py-4">
    <div class="admin-form-card mx-auto">
        <form asp-action="UpdateCityLeaders" method="post" class="admin-form">

            <div class="mb-3">
                <label asp-for="CityId" class="form-label fw-bold">
                    <i class="bi bi-geo-alt-fill me-2"></i>@Localizer["UPLCity"]
                </label>

                <select asp-for="CityId"
                        class="form-select form-select-lg tg-select"
                        asp-items="@(new SelectList(Model.Cities, "Id", "Name"))">
                </select>

                <span asp-validation-for="CityId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TeamId" class="form-label fw-bold">
                    <i class="bi bi-people-fill me-2"></i>@Localizer["UPLTeam"]
                </label>

                <select asp-for="TeamId"
                        class="form-select form-select-lg tg-select"
                        asp-items="@(new SelectList(Model.Teams, "Id", "Name"))">
                </select>

                <span asp-validation-for="TeamId" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success btn-lg w-100 tg-action-btn">
                <i class="bi bi-plus-circle-fill me-2"></i>
                @Localizer["UPLAddWin"]
            </button>

        </form>
    </div>

</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
