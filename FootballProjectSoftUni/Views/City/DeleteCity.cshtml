@using FootballProjectSoftUni.Core.Models.City
@model List<CityViewModel>
@inject IStringLocalizer<FootballProjectSoftUni.SharedResource> Localizer

<section class="container py-4">
    <div class="admin-form-card mx-auto">

        <form asp-action="Delete" method="post">

            <div class="mb-3">
                <label class="form-label fw-bold">
                    <i class="bi bi-geo-alt-fill me-2"></i>@Localizer["DeleteSelectCity"]
                </label>

                <select name="cityId"
                        id="cityId"
                        class="form-select form-select-lg tg-select">

                    @foreach (var city in Model)
                    {
                        <option value="@city.Id">@city.Name</option>
                    }
                </select>
            </div>

            <a id="deleteButton"
               class="btn btn-danger btn-lg w-100 tg-action-btn disabled">

                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @Localizer["DeleteDeleteCity"]
            </a>

        </form>

    </div>

</section>

<script>
    const citySelect = document.getElementById('cityId');
    const deleteButton = document.getElementById('deleteButton');

    citySelect.addEventListener('change', function () {

        if (this.value) {
            deleteButton.href = '/City/DeleteConfirmed/' + this.value;
            deleteButton.classList.remove('disabled');
        } else {
            deleteButton.href = '#';
            deleteButton.classList.add('disabled');
        }

    });
</script>
