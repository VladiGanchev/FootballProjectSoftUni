@model FootballProjectSoftUni.Core.Models.Home.HomeViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = "Tournament Galaxy";
}

<section class="hero">
    <div class="hero__bg"
         style="background-image:url('https://fcdynamo.com/img/4ed49bb5-4123-4d5c-b5ce-7e6b1d5aa1e9/3fd4154410720ba54ec935ce9e460a191210.jpg?fm=jpg&q=80&fit=max&crop=900%2C506%2C0%2C0');">
    </div>
    <div class="hero__overlay"></div>

    <div class="container position-relative">
        <div class="row align-items-center g-4 py-5">
            <div class="col-lg-7">
                <h1 class="hero-title mb-3">Tournament Galaxy</h1>
            </div>

            <div class="col-lg-5">
                <div class="hero-card p-4 p-md-5">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h5 class="mb-0">@Localizer["IndexOurAchievements"]</h5>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="stat stat--primary">
                                <div class="stat__icon"><i class="bi bi-trophy"></i></div>
                                <div class="stat__value">@Model.TournamentsCount</div>
                                <div class="stat__label">@Localizer["IndexTournaments"]</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat stat--success">
                                <div class="stat__icon"><i class="bi bi-people"></i></div>
                                <div class="stat__value">@Model.TeamsCount</div>
                                <div class="stat__label">@Localizer["IndexTeams"]</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat stat--danger">
                                <div class="stat__icon"><i class="bi bi-person-badge"></i></div>
                                <div class="stat__value">@Model.PlayersCount</div>
                                <div class="stat__label">@Localizer["IndexPlayers"]</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="stat stat--warning">
                                <div class="stat__icon"><i class="bi bi-calendar-event"></i></div>
                                <div class="stat__value">@Model.YearOfFoundation</div>
                                <div class="stat__label">@Localizer["IndexFounded"]</div>
                            </div>
                        </div>
                    </div>

                    <hr class="hr-soft my-4" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-lightning-charge-fill"></i></div>
                <h5 class="mb-2">@Localizer["IndexTFastManagement"]</h5>
                <p class="mb-0 text-muted">@Localizer["IndexCreateTeam"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-diagram-3-fill"></i></div>
                <h5 class="mb-2">@Localizer["IndexClearStructure"]</h5>
                <p class="mb-0 text-muted">@Localizer["IndexTeamPlayers"]</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-award-fill"></i></div>
                <h5 class="mb-2">@Localizer["IndexFollowResults"]</h5>
                <p class="mb-0 text-muted">@Localizer["IndexFollowRanking"]</p>
            </div>
        </div>
    </div>
</section>
