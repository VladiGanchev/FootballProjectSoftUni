@page
@model ResetPasswordConfirmationModel
@inject IStringLocalizer<FootballProjectSoftUni.SharedResource> Localizer

@{
    ViewData["Title"] = "Password reset successful";
}

<div class="auth-wrap">
    <div class="auth-card text-center">

        <div class="auth-logo mb-3">
            <i class="bi bi-check-circle-fill"></i>
        </div>

        <h1 class="auth-title mb-2">@Localizer["FPCPassReset"]</h1>

        <p class="auth-subtitle mb-4">
            @Localizer["FPCPassResetSuccess"]
        </p>

        <a asp-page="./Login" class="btn btn-primary auth-btn">
            <i class="bi bi-box-arrow-in-right me-2"></i>
            @Localizer["FPCLogin"]
        </a>

    </div>
</div>
